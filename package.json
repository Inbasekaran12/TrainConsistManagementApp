{
  "name": "smart-traffic-route-optimizer",
  "version": "1.0.0",
  "description": "A browser-based pathfinding visualization app using A* and Uniform Cost Search.",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --coverage",
    "start": "npx http-server ./src -p 8080 -c-1",
    "lint": "eslint ."
  },
  "devDependencies": {
    "eslint": "^9.30.1",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1"
  }
}
